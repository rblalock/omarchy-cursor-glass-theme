  --vscode-diffEditor-insertedLineBackground: {alpha(p['color2'], .28)} !important;
  --vscode-diffEditor-removedLineBackground: {alpha(p['color1'], .28)} !important;
  --vscode-terminal-ansiBlack: {p['color0']} !important;
  --vscode-terminal-ansiRed: {p['color1']} !important;
  --vscode-terminal-ansiGreen: {p['color2']} !important;
  --vscode-terminal-ansiYellow: {p['color3']} !important;
  --vscode-terminal-ansiBlue: {p['color4']} !important;
  --vscode-terminal-ansiMagenta: {p['color5']} !important;
  --vscode-terminal-ansiCyan: {p['color6']} !important;
  --vscode-terminal-ansiWhite: {p['color7']} !important;
  --cursor-text-primary: {fg} !important;
  --cursor-text-secondary: {alpha(fg, .74)} !important;
  --cursor-text-tertiary: {alpha(fg, .54)} !important;
  --cursor-text-quaternary: {alpha(fg, .36)} !important;
  --cursor-bg-primary: {alpha(fg, .14)} !important;
  --cursor-bg-secondary: {surface2} !important;
  --cursor-bg-tertiary: {surface} !important;
  --cursor-bg-quaternary: {surface2} !important;
  --cursor-bg-elevated: {surface2} !important;
  --cursor-bg-active: {surface2} !important;
  --cursor-bg-focused: {surface2} !important;
  --cursor-stroke-primary: {alpha(accent, .34)} !important;
  --cursor-stroke-secondary: {alpha(accent, .22)} !important;
  --cursor-stroke-tertiary: {alpha(fg, .10)} !important;
  --cursor-stroke-focused: {accent} !important;
  --cursor-icon-primary: {fg} !important;
