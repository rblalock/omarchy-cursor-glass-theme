def sudo_prefix(non_interactive: bool) -> list[str]:
    return ["sudo", "-n"] if non_interactive else ["sudo"]


def write_root_file(path: Path, content: str, non_interactive: bool) -> None:
    if os.access(path, os.W_OK):
        path.write_text(content)
        return
    with tempfile.NamedTemporaryFile("w", delete=False) as f:
        f.write(content)
        tmp = f.name
    try:
        run(sudo_prefix(non_interactive) + ["cp", tmp, str(path)])
    finally:
        os.unlink(tmp)


def ensure_backup(non_interactive: bool) -> None:
    if BACKUP.exists():
        return
    if os.access(CURSOR_CSS.parent, os.W_OK):
        shutil.copy2(CURSOR_CSS, BACKUP)
    else:
        run(sudo_prefix(non_interactive) + ["cp", str(CURSOR_CSS), str(BACKUP)])


def remove_marked(text: str, start: str, end: str) -> str:
    return re.sub(re.escape(start) + r".*?" + re.escape(end) + r"\n?", "", text, flags=re.S)


def grant_write_access(non_interactive: bool) -> None:
    """Allow the current user to update Cursor's CSS so Omarchy hooks can run without sudo."""
    if os.access(CURSOR_CSS, os.W_OK):
        print(f"Current user can already write {CURSOR_CSS}")
        return
    if shutil.which("setfacl") is None:
        raise SystemExit("setfacl is required to grant hook write access. Install the acl package, or run apply manually with sudo when needed.")
    user = os.environ.get("SUDO_USER") or os.environ.get("USER") or subprocess.check_output(["id", "-un"], text=True).strip()
    run(sudo_prefix(non_interactive) + ["setfacl", "-m", f"u:{user}:rw", str(CURSOR_CSS)])
    print(f"Granted write access on Cursor CSS to user '{user}'.")


def apply(theme: str | None, non_interactive: bool) -> None:
    # Direct patch is intentional. A file:// @import loader was tested and Electron did not
    # reliably load it for Cursor Agents. Direct patching is the working path.
    theme_name = theme or current_theme()
    theme_dir = find_theme_dir(theme_name)
    if not theme_dir:
        raise SystemExit(f"Theme not found: {theme_name}")
    ensure_backup(non_interactive)
    original = CURSOR_CSS.read_text(errors="ignore")
    original = remove_marked(original, START, END)
    original = remove_marked(original, LOADER_START, LOADER_END)
    block = css_for(theme_dir.name, read_palette(theme_dir))
    write_root_file(CURSOR_CSS, original.rstrip() + "\n\n" + block.strip() + "\n", non_interactive)
    print(f"Applied Cursor Agents Glass theme from Omarchy theme '{theme_dir.name}'.")
    print("Fully quit/relaunch Cursor Agents to see changes.")


def restore(non_interactive: bool) -> None:
    if BACKUP.exists():
        if os.access(CURSOR_CSS, os.W_OK):
            shutil.copy2(BACKUP, CURSOR_CSS)
        else:
            run(sudo_prefix(non_interactive) + ["cp", str(BACKUP), str(CURSOR_CSS)])
        print("Restored Cursor CSS from backup.")
    else:
        text = CURSOR_CSS.read_text(errors="ignore")
        text = remove_marked(remove_marked(text, START, END), LOADER_START, LOADER_END)
        write_root_file(CURSOR_CSS, text, non_interactive)
        print("Removed Cursor Agents patch/loader blocks.")


def install_hook() -> None:
    HOOK.parent.mkdir(parents=True, exist_ok=True)
    if not HOOK.exists():
        HOOK.write_text("#!/usr/bin/env bash\n# Called with the snake-cased name of the Omarchy theme just set.\n")
        HOOK.chmod(0o755)
    text = HOOK.read_text()

    # Remove older unmarked blocks from pre-release versions.
    text = re.sub(
        r"\n?# Sync Cursor Agents Glass theme to Omarchy\.\n"
        r"if command -v cursor-omarchy-agent-theme >/dev/null 2>&1; then\n"
        r"  cursor-omarchy-agent-theme apply \"\$1\" \|\| true\n"
        r"fi\n?",
        "\n",
        text,
    )

    hook_start = "# >>> cursor-omarchy-agent-theme hook >>>"
    hook_end = "# <<< cursor-omarchy-agent-theme hook <<<"
    tool = HOME / ".local/bin/cursor-omarchy-agent-theme"
    block = f"""
{hook_start}
# Sync Cursor Agents Glass theme to Omarchy.
if [ -x "{tool}" ]; then
  "{tool}" apply "$1" || true
elif command -v cursor-omarchy-agent-theme >/dev/null 2>&1; then
  cursor-omarchy-agent-theme apply "$1" || true
fi
{hook_end}
"""
    text = remove_marked(text, hook_start, hook_end)
    marker = "# >>> omazed hook - do not edit >>>"
    if marker in text:
        text = text.replace(marker, block + "\n" + marker)
    else:
        text = text.rstrip() + "\n" + block
    HOOK.write_text(text)
    HOOK.chmod(0o755)
    print(f"Installed Omarchy theme hook in {HOOK}")


def status() -> None:
    text = CURSOR_CSS.read_text(errors="ignore") if CURSOR_CSS.exists() else ""
    print(f"Cursor CSS: {CURSOR_CSS}")
    print(f"Backup: {'yes' if BACKUP.exists() else 'no'} ({BACKUP})")
    print(f"Patch installed: {'yes' if START in text else 'no'}")
    print(f"Legacy loader present: {'yes' if LOADER_START in text else 'no'}")
    print(f"Writable by current user: {'yes' if os.access(CURSOR_CSS, os.W_OK) else 'no'}")
    print(f"Omarchy hook: {'yes' if HOOK.exists() and 'cursor-omarchy-agent-theme apply' in HOOK.read_text(errors='ignore') else 'no'} ({HOOK})")


def main() -> int:
    parser = argparse.ArgumentParser(description="Theme Cursor Agents from Omarchy themes")
    sub = parser.add_subparsers(dest="cmd", required=True)
    p_apply = sub.add_parser("apply", help="Patch Cursor Agents Glass CSS from an Omarchy theme")
    p_apply.add_argument("theme", nargs="?", help="Omarchy theme name; defaults to current theme")
    p_apply.add_argument("--non-interactive", action="store_true", help="Use sudo -n if privileges are needed")
    p_grant = sub.add_parser("grant-write-access", help="Allow theme hook to patch Cursor CSS without sudo")
    p_grant.add_argument("--non-interactive", action="store_true")
    sub.add_parser("install-hook", help="Run apply after omarchy theme set")
    p_restore = sub.add_parser("restore", help="Restore Cursor CSS from backup")
    p_restore.add_argument("--non-interactive", action="store_true")
    sub.add_parser("status")
    args = parser.parse_args()
    if args.cmd == "apply":
        apply(args.theme, args.non_interactive)
    elif args.cmd == "grant-write-access":
        grant_write_access(args.non_interactive)
    elif args.cmd == "install-hook":
        install_hook()
    elif args.cmd == "restore":
        restore(args.non_interactive)
    elif args.cmd == "status":
        status()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
