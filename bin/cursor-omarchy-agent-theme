#!/usr/bin/env python3
"""Theme Cursor Agents (Glass UI) from Omarchy themes."""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import tempfile
import tomllib
from pathlib import Path

HOME = Path.home()
THEME_ROOTS = [HOME / ".config/omarchy/themes", HOME / ".local/share/omarchy/themes"]
CURSOR_CSS = Path("/usr/share/cursor/resources/app/out/vs/workbench/workbench.desktop.main.css")
BACKUP = CURSOR_CSS.with_suffix(CURSOR_CSS.suffix + ".bak.cursor-omarchy-agent-theme")
HOOK = HOME / ".config/omarchy/hooks/theme-set"
START = "/* >>> cursor-omarchy-agent-theme >>> */"
END = "/* <<< cursor-omarchy-agent-theme <<< */"
# Older experimental versions installed an @import loader. Keep these markers so
# apply/restore can remove it if present.
LOADER_START = "/* >>> cursor-omarchy-agent-theme loader >>> */"
LOADER_END = "/* <<< cursor-omarchy-agent-theme loader <<< */"


def run(cmd: list[str]) -> None:
    subprocess.run(cmd, text=True, check=True)


def slug(s: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", s.lower()).strip("-")


def current_theme() -> str:
    return subprocess.check_output(["omarchy", "theme", "current"], text=True).strip()


def find_theme_dir(name: str) -> Path | None:
    wanted = slug(name)
    for root in THEME_ROOTS:
        if root.exists():
            for d in root.iterdir():
                if d.is_dir() and (slug(d.name) == wanted or d.name == name):
                    return d
    return None


def valid_hex(v: object) -> bool:
    return isinstance(v, str) and re.fullmatch(r"#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?", v) is not None


def read_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(errors="ignore"))
    except Exception:
        return {}


def merge_theme_json(path: Path, seen: set[Path] | None = None) -> dict:
    seen = seen or set()
    path = path.resolve()
    if path in seen or not path.exists():
        return {}
    seen.add(path)
    data = read_json(path)
    merged = {}
    include = data.get("include")
    if isinstance(include, str):
        merged.update(merge_theme_json(path.parent / include, seen))
    merged.update(data)
    if isinstance(data.get("colors"), dict):
        colors = dict(merged.get("colors", {})) if isinstance(merged.get("colors"), dict) else {}
        colors.update(data["colors"])
        merged["colors"] = colors
    return merged


def find_installed_vscode_theme(vscode_meta: dict) -> dict:
    ext = vscode_meta.get("extension")
    wanted_name = vscode_meta.get("name")
    if not isinstance(ext, str) or not ext:
        return {}
    ext_slug = ext.lower()
    roots = [HOME / ".cursor/extensions", HOME / ".vscode/extensions"]
    for root in roots:
        if not root.exists():
            continue
        for d in root.iterdir():
            if not d.is_dir() or not d.name.lower().startswith(ext_slug):
                continue
            pkg = read_json(d / "package.json")
            themes = (((pkg.get("contributes") or {}).get("themes")) or []) if isinstance(pkg, dict) else []
            for t in themes:
                label = t.get("label") or t.get("id")
                if wanted_name and label != wanted_name:
                    continue
                rel = t.get("path")
                if isinstance(rel, str):
                    return merge_theme_json(d / rel)
            # If name didn't match, fall back to the first contributed theme.
            if themes and isinstance(themes[0].get("path"), str):
                return merge_theme_json(d / themes[0]["path"])
    return {}


def vscode_palette(theme_dir: Path) -> dict[str, str]:
    meta_path = theme_dir / "vscode.json"
    if not meta_path.exists():
        return {}
    meta = read_json(meta_path)
    data = meta if isinstance(meta.get("colors"), dict) else find_installed_vscode_theme(meta)
    colors = data.get("colors") if isinstance(data, dict) else None
    if not isinstance(colors, dict):
        return {}

    def color(*keys: str) -> str | None:
        for key in keys:
            v = colors.get(key)
            if valid_hex(v):
                return str(v)[:7]
        return None

    p: dict[str, str] = {}
    mapping = {
        "background": ("editor.background", "sideBar.background", "panel.background"),
        "foreground": ("editor.foreground", "foreground", "sideBar.foreground"),
        "accent": ("button.background", "focusBorder", "activityBar.activeBorder", "activityBar.foreground"),
        "cursor": ("editorCursor.foreground",),
        "selection_background": ("editor.selectionBackground", "selection.background", "list.activeSelectionBackground"),
        "selection_foreground": ("editor.selectionForeground", "button.foreground",),
    }
    for out, keys in mapping.items():
        v = color(*keys)
        if v:
            p[out] = v
    ansi = [
        "terminal.ansiBlack", "terminal.ansiRed", "terminal.ansiGreen", "terminal.ansiYellow",
        "terminal.ansiBlue", "terminal.ansiMagenta", "terminal.ansiCyan", "terminal.ansiWhite",
        "terminal.ansiBrightBlack", "terminal.ansiBrightRed", "terminal.ansiBrightGreen", "terminal.ansiBrightYellow",
        "terminal.ansiBrightBlue", "terminal.ansiBrightMagenta", "terminal.ansiBrightCyan", "terminal.ansiBrightWhite",
    ]
    for i, key in enumerate(ansi):
        v = color(key)
        if v:
            p[f"color{i}"] = v
    return p


def read_palette(theme_dir: Path) -> dict[str, str]:
    # Prefer an explicit/installed VS Code theme when the Omarchy theme provides one,
    # then fill any missing values from Omarchy colors.toml and other theme files.
    p: dict[str, str] = vscode_palette(theme_dir)
    colors = theme_dir / "colors.toml"
    if colors.exists():
        for k, v in tomllib.loads(colors.read_text()).items():
            if valid_hex(v):
                p.setdefault(k, str(v)[:7])

    waybar = theme_dir / "waybar.css"
    if waybar.exists():
        text = waybar.read_text(errors="ignore")
        for key, css_key in [("background", "bg"), ("foreground", "foreground"), ("accent", "accent")]:
            if key not in p:
                m = re.search(rf"@define-color\s+{css_key}\s+(#[0-9a-fA-F]{{6}})", text)
                if m:
                    p[key] = m.group(1)

    hypr = theme_dir / "hyprland.conf"
    if hypr.exists() and "accent" not in p:
        m = re.search(r"activeBorderColor\s*=\s*rgb\(([0-9a-fA-F]{6})\)", hypr.read_text(errors="ignore"))
        if m:
            p["accent"] = "#" + m.group(1)

    p.setdefault("background", "#141414")
    p.setdefault("foreground", "#e4e4e4")
    p.setdefault("accent", p.get("color4", "#82d2ce"))
    p.setdefault("cursor", p["accent"])
    p.setdefault("selection_background", p["accent"])
    p.setdefault("selection_foreground", p["background"])
    defaults = ["#000000", "#cd3131", "#0dbc79", "#e5e510", "#2472c8", "#bc3fbc", "#11a8cd", "#e5e5e5", "#666666", "#f14c4c", "#23d18b", "#f5f543", "#3b8eea", "#d670d6", "#29b8db", "#ffffff"]
    for i, color in enumerate(defaults):
        p.setdefault(f"color{i}", color)
    return p


def hex_to_rgb(h: str) -> tuple[int, int, int]:
    h = h.lstrip("#")[:6]
    return int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)


def mix(a: str, b: str, amount: float) -> str:
    ar, ag, ab = hex_to_rgb(a)
    br, bg, bb = hex_to_rgb(b)
    return f"#{round(ar + (br-ar)*amount):02x}{round(ag + (bg-ag)*amount):02x}{round(ab + (bb-ab)*amount):02x}"


def alpha(h: str, a: float) -> str:
    r, g, b = hex_to_rgb(h)
    return f"rgba({r}, {g}, {b}, {a:.3g})"


def css_for(theme_name: str, p: dict[str, str]) -> str:
    bg = p["background"]
    fg = p["foreground"]
    accent = p["accent"]
    surface = mix(bg, fg, 0.06)
    surface2 = mix(bg, fg, 0.10)
    surface3 = mix(bg, fg, 0.14)
    selection = p["selection_background"]

    # Cursor Agents' Glass UI is translucent by default. For theme fidelity we make
    # the major app/editor/sidebar surfaces use the theme editor background, and
    # use a slightly raised surface for rows, cards, tabs, and inputs.
    return f"""{START}
/* Generated from Omarchy theme: {theme_name} */
body[data-cursor-glass-mode="true"] {{
  --vscode-foreground: {fg} !important;
  --vscode-descriptionForeground: {alpha(fg, .72)} !important;
  --vscode-editor-background: {bg} !important;
  --vscode-editor-foreground: {fg} !important;
  --vscode-sideBar-background: {bg} !important;
  --vscode-sideBarSectionHeader-background: {bg} !important;
  --vscode-sideBarTitle-background: {bg} !important;
  --vscode-activityBar-background: {bg} !important;
  --vscode-titleBar-activeBackground: {bg} !important;
  --vscode-titleBar-inactiveBackground: {bg} !important;
  --vscode-titleBar-activeForeground: {fg} !important;
  --vscode-titleBar-inactiveForeground: {alpha(fg, .62)} !important;
  --vscode-input-background: {surface2} !important;
  --vscode-input-foreground: {fg} !important;
  --vscode-dropdown-background: {surface2} !important;
  --vscode-quickInput-background: {surface2} !important;
  --vscode-editorWidget-background: {surface2} !important;
  --vscode-editorWidget-border: {alpha(accent, .24)} !important;
  --vscode-editorGroupHeader-tabsBackground: {bg} !important;
  --vscode-editorGroupHeader-tabsBorder: {alpha(accent, .18)} !important;
  --vscode-editorGroup-border: {alpha(accent, .20)} !important;
  --vscode-editorPane-background: {bg} !important;
  --vscode-tab-activeBackground: {bg} !important;
  --vscode-tab-inactiveBackground: {bg} !important;
  --vscode-tab-hoverBackground: {surface2} !important;
  --vscode-tab-border: {alpha(accent, .16)} !important;
  --vscode-breadcrumb-background: {bg} !important;
  --vscode-breadcrumb-foreground: {alpha(fg, .72)} !important;
  --vscode-breadcrumb-focusForeground: {fg} !important;
  --vscode-list-activeSelectionBackground: {surface2} !important;
  --vscode-list-inactiveSelectionBackground: {surface2} !important;
  --vscode-list-focusBackground: {surface2} !important;
  --vscode-list-hoverBackground: {surface2} !important;
